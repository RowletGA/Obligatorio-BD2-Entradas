@model ReportesViewModel
@{ ViewData["Title"] = "Reportes"; }
<section class="page-heading"><p class="section-kicker">Administración</p><h1>Reportes</h1></section>
<form method="get" class="content-panel mb-3">
    <div class="form-section">
        <div><label asp-for="Desde" class="form-label"></label><input asp-for="Desde" class="form-control" type="date" /></div>
        <div><label asp-for="Hasta" class="form-label"></label><input asp-for="Hasta" class="form-control" type="date" /></div>
        <div><label asp-for="Limite" class="form-label"></label><input asp-for="Limite" class="form-control" type="number" min="1" max="100" /></div>
    </div>
    <button class="btn btn-primary mt-3">Aplicar</button>
</form>
<section class="content-panel mb-3"><h2 class="h5">Eventos con más entradas vendidas</h2>
@if (Model.Eventos.Count == 0) { <p class="text-secondary mb-0">Sin datos.</p> } else { <div class="table-responsive"><table class="table"><thead><tr><th>Evento</th><th>Fecha</th><th>Estadio</th><th>Vendidas</th></tr></thead><tbody>@foreach (var e in Model.Eventos) { <tr><td>@e.Evento</td><td>@e.FechaHora.ToString("g")</td><td>@e.Estadio</td><td>@e.EntradasVendidas</td></tr> }</tbody></table></div> }
</section>
<section class="content-panel"><h2 class="h5">Mayores compradores</h2>
@if (Model.Compradores.Count == 0) { <p class="text-secondary mb-0">Sin datos.</p> } else { <div class="table-responsive"><table class="table"><thead><tr><th>Comprador</th><th>Correo</th><th>Entradas</th><th>Total</th></tr></thead><tbody>@foreach (var c in Model.Compradores) { <tr><td>@c.Comprador</td><td>@c.Correo</td><td>@c.EntradasCompradas</td><td>$ @c.TotalGastado.ToString("N2")</td></tr> }</tbody></table></div> }
</section>
