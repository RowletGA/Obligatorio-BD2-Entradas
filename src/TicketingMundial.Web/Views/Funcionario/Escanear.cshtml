@model ValidarQrViewModel
@{ ViewData["Title"] = "Escanear entrada"; }

<section class="page-heading"><p class="section-kicker">Funcionario</p><h1>Escanear entradas</h1></section>

<section class="content-panel mb-3" data-qr-image-reader>
    <h2 class="h5 mb-1">Cargar imagen</h2>
    <p class="text-secondary">Seleccioná una captura, PNG, JPG, WebP o foto del QR.</p>
    <input type="file" accept="image/png,image/jpeg,image/webp,image/*" capture="environment" class="form-control" data-qr-file />
    <div class="mt-3 d-flex flex-column flex-md-row gap-3 align-items-start">
        <img data-qr-preview alt="Vista previa del QR" class="img-fluid rounded border d-none" style="max-width: 240px" />
        <div>
            <p class="text-secondary mb-2" data-image-status>La imagen se procesa en este navegador y no se envía al servidor.</p>
            <button type="submit" class="btn btn-primary" form="qr-validation-form" data-image-validate disabled>Validar imagen</button>
        </div>
    </div>
</section>

<section class="content-panel mb-3" data-qr-scanner>
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
        <div>
            <h2 class="h5 mb-1">Cámara</h2>
            <p class="text-secondary mb-0">Apuntá al QR dinámico de la entrada.</p>
        </div>
        <button type="button" class="btn btn-outline-primary" data-scan-again>Escanear</button>
    </div>
    <video data-video autoplay playsinline muted class="w-100 rounded border bg-dark" style="max-height: 360px"></video>
    <p class="text-secondary mt-3 mb-0" data-scan-status>Preparando cámara...</p>
</section>

<form asp-action="ValidarQr" method="post" class="content-panel mb-3" id="qr-validation-form" data-qr-form>
    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
    <label asp-for="Token" class="form-label">Token QR</label>
    <textarea asp-for="Token" class="form-control" rows="3" maxlength="255" autocomplete="off"></textarea>
    <button class="btn btn-primary mt-3">Validar</button>
</form>

@if (Model.Resultado is not null)
{
    <section class="content-panel">
        <h2 class="h5">Resultado</h2>
        <div class="detail-grid">
            <div><span>Estado</span><strong>@(Model.Resultado.EstadoEntrada == "VALIDADA" ? "Entrada válida" : Model.Resultado.ResultadoValidacion)</strong></div>
            <div><span>Evento</span><strong>@Model.Resultado.Evento</strong></div>
            <div><span>Fecha</span><strong>@Model.Resultado.FechaEvento.ToString("dd/MM/yyyy HH:mm")</strong></div>
            <div><span>Estadio</span><strong>@Model.Resultado.Estadio</strong></div>
            <div><span>Sector</span><strong>@Model.Resultado.Sector</strong></div>
            <div><span>Validación</span><strong>@(Model.Resultado.FechaHoraValidacion?.ToString("dd/MM/yyyy HH:mm") ?? "Registrada")</strong></div>
        </div>
        <a class="btn btn-outline-primary mt-3" asp-action="Escanear">Validar otro QR</a>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const root = document.querySelector("[data-qr-scanner]");
            const imageRoot = document.querySelector("[data-qr-image-reader]");
            const form = document.querySelector("[data-qr-form]");
            if (!root || !form) return;

            const video = root.querySelector("[data-video]");
            const status = root.querySelector("[data-scan-status]");
            const scanAgain = root.querySelector("[data-scan-again]");
            const fileInput = imageRoot?.querySelector("[data-qr-file]");
            const imageStatus = imageRoot?.querySelector("[data-image-status]");
            const preview = imageRoot?.querySelector("[data-qr-preview]");
            const imageValidate = imageRoot?.querySelector("[data-image-validate]");
            const tokenInput = form.querySelector("[name='Token']");
            let stream = null;
            let detector = null;
            let scanning = false;
            let submitting = false;
            let previewUrl = null;

            const setStatus = (text) => { status.textContent = text; };
            const setImageStatus = (text) => { if (imageStatus) imageStatus.textContent = text; };
            const maxImageBytes = 10 * 1024 * 1024;
            const stopCamera = () => {
                scanning = false;
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                    stream = null;
                }
            };
            const clearPreview = () => {
                if (previewUrl) {
                    URL.revokeObjectURL(previewUrl);
                    previewUrl = null;
                }
            };

            const submitToken = (token) => {
                if (submitting) return;
                submitting = true;
                stopCamera();
                tokenInput.value = token;
                setStatus("Validando...");
                form.submit();
            };

            const setTokenFromImage = (token) => {
                tokenInput.value = token;
                if (imageValidate) imageValidate.disabled = false;
            };

            const getDetector = () => {
                if (!("BarcodeDetector" in window)) return null;
                detector ??= new BarcodeDetector({ formats: ["qr_code"] });
                return detector;
            };

            const scanLoop = async () => {
                if (!scanning || !detector) return;
                try {
                    const codes = await detector.detect(video);
                    if (codes.length > 0 && codes[0].rawValue) {
                        setStatus("QR detectado.");
                        submitToken(codes[0].rawValue);
                        return;
                    }
                } catch {
                    setStatus("No se pudo leer la imagen de la cámara.");
                }
                window.requestAnimationFrame(scanLoop);
            };

            const start = async () => {
                stopCamera();
                submitting = false;
                if (!("BarcodeDetector" in window)) {
                    setStatus("El navegador no soporta detección automática. Usá el formulario manual.");
                    return;
                }

                try {
                    detector = getDetector();
                    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: "environment" } }, audio: false });
                    video.srcObject = stream;
                    await video.play();
                    scanning = true;
                    setStatus("Buscando QR...");
                    scanLoop();
                } catch {
                    setStatus("Cámara no disponible o permiso rechazado. Usá el formulario manual.");
                }
            };

            const processImage = async (file) => {
                if (!file) return;
                if (imageValidate) imageValidate.disabled = true;
                tokenInput.value = "";
                if (file.size <= 0) {
                    setImageStatus("El archivo está vacío.");
                    return;
                }
                if (file.size > maxImageBytes) {
                    setImageStatus("La imagen supera el máximo de 10 MB.");
                    return;
                }
                if (!file.type.startsWith("image/")) {
                    setImageStatus("Seleccioná un archivo de imagen válido.");
                    return;
                }
                const localDetector = getDetector();
                if (!localDetector) {
                    setImageStatus("Este navegador no permite leer códigos QR desde imágenes. Podés usar otro navegador o ingresar el token manualmente.");
                    return;
                }

                clearPreview();
                previewUrl = URL.createObjectURL(file);
                if (preview) {
                    preview.src = previewUrl;
                    preview.classList.remove("d-none");
                }

                let imageBitmap = null;
                try {
                    setImageStatus("Leyendo imagen...");
                    imageBitmap = await createImageBitmap(file);
                    const codes = await localDetector.detect(imageBitmap);
                    if (codes.length === 0) {
                        setImageStatus("No se encontró un código QR en la imagen.");
                        return;
                    }
                    if (codes.length > 1) {
                        setImageStatus("La imagen contiene más de un código QR.");
                        return;
                    }
                    if (!codes[0].rawValue) {
                        setImageStatus("No se pudo leer el contenido del QR.");
                        return;
                    }
                    setTokenFromImage(codes[0].rawValue);
                    setImageStatus("QR detectado. Presioná Validar imagen para confirmar.");
                } catch {
                    setImageStatus("No se pudo procesar la imagen.");
                } finally {
                    if (imageBitmap) imageBitmap.close();
                }
            };

            scanAgain.addEventListener("click", start);
            fileInput?.addEventListener("change", () => {
                processImage(fileInput.files?.[0]);
            });
            window.addEventListener("pagehide", stopCamera);
            window.addEventListener("pagehide", clearPreview);
            document.addEventListener("visibilitychange", () => {
                if (document.hidden) stopCamera();
            });

            start();
        })();
    </script>
}
