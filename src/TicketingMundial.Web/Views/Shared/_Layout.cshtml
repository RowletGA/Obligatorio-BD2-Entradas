@using TicketingMundial.Web.Extensions
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    IReadOnlyList<string> rolesReales = isAuthenticated ? User.GetRolesReales() : Array.Empty<string>();
    var perfilActivo = isAuthenticated ? User.GetPerfilActivoSeguro() : null;
    var tieneMultiplesPerfiles = isAuthenticated && rolesReales.Count > 1;
    var nombrePerfilActivo = perfilActivo is null ? "Seleccionar perfil" : PerfilActivoExtensions.GetNombrePerfil(perfilActivo);
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Ticketing Mundial</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="app-frame">
        <aside class="app-sidebar">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                <span class="brand-title">WorldCup Tickets</span>
                <span class="brand-subtitle">BD2 · Mundial 2026</span>
            </a>

            @if (isAuthenticated)
            {
                <div class="role-card">
                    <span>Perfil activo</span>
                    <strong>@User.Identity?.Name</strong>
                    <small>@nombrePerfilActivo</small>
                </div>
            }

            <nav class="app-nav">
                @if (!isAuthenticated)
                {
                    <a asp-controller="Home" asp-action="Index">Inicio</a>
                    <a asp-controller="Eventos" asp-action="Index">Eventos</a>
                    <a asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                    <a asp-controller="Account" asp-action="Register">Registrarse</a>
                }
                else if (perfilActivo == RolesAplicacion.UsuarioGeneral)
                {
                    <a asp-controller="Home" asp-action="Index">Inicio</a>
                    <a asp-controller="Eventos" asp-action="Index">Eventos</a>
                    <a asp-controller="Compras" asp-action="Index">Mis compras</a>
                    <a asp-controller="Entradas" asp-action="MisEntradas">Mis entradas</a>
                    <a asp-controller="Transferencias" asp-action="Index">Transferencias</a>
                    <a asp-controller="Account" asp-action="Profile">Mi perfil</a>
                }
                else if (perfilActivo == RolesAplicacion.Administrador)
                {
                    <a asp-controller="Admin" asp-action="Index">Dashboard</a>
                    <a asp-controller="Admin" asp-action="Estadios">Estadios</a>
                    <a asp-controller="Admin" asp-action="Sectores">Sectores</a>
                    <a asp-controller="Admin" asp-action="Equipos">Equipos</a>
                    <a asp-controller="Admin" asp-action="Eventos">Eventos</a>
                    <a asp-controller="Admin" asp-action="Funcionarios">Funcionarios</a>
                    <a asp-controller="Reportes" asp-action="Index">Reportes</a>
                }
                else if (perfilActivo == RolesAplicacion.Funcionario)
                {
                    <a asp-controller="Funcionario" asp-action="Index">Eventos asignados</a>
                    <a asp-controller="Funcionario" asp-action="Escanear">Escanear entradas</a>
                    <a asp-controller="Funcionario" asp-action="Index" asp-fragment="historial">Historial</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="SeleccionarPerfil">Seleccionar perfil</a>
                }

                @if (tieneMultiplesPerfiles)
                {
                    <a asp-controller="Account" asp-action="SeleccionarPerfil">Cambiar perfil</a>
                }
            </nav>

            @if (isAuthenticated)
            {
                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-auto">
                    <button type="submit" class="btn btn-outline-secondary w-100">Cerrar sesión</button>
                </form>
            }
        </aside>

        <header class="mobile-header">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                <span class="brand-title">WorldCup Tickets</span>
                <span class="brand-subtitle">Mundial 2026</span>
            </a>
            <div class="mobile-scroll-nav">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Eventos" asp-action="Index">Eventos</a>
                @if (!isAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                    <a asp-controller="Account" asp-action="Register">Registrarse</a>
                }
                else
                {
                    <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    @if (perfilActivo == RolesAplicacion.UsuarioGeneral)
                    {
                        <a asp-controller="Compras" asp-action="Index">Mis compras</a>
                        <a asp-controller="Entradas" asp-action="MisEntradas">Mis entradas</a>
                    }
                    else if (perfilActivo == RolesAplicacion.Funcionario)
                    {
                        <a asp-controller="Funcionario" asp-action="Index">Eventos asignados</a>
                        <a asp-controller="Funcionario" asp-action="Escanear">Escanear entradas</a>
                        <a asp-controller="Funcionario" asp-action="Index" asp-fragment="historial">Historial</a>
                    }
                    @if (tieneMultiplesPerfiles)
                    {
                        <a asp-controller="Account" asp-action="SeleccionarPerfil">Cambiar perfil</a>
                    }
                }
            </div>
        </header>

        <main class="app-main">
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger" role="alert">@error</div>
            }
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success" role="alert">@success</div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
