@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var dashboardAction = User.IsInRole(RolesAplicacion.Administrador)
        ? "Administrador"
        : User.IsInRole(RolesAplicacion.Funcionario)
            ? "Funcionario"
            : "Usuario";
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Ticketing Mundial</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="app-frame">
        <aside class="app-sidebar">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                <span class="brand-title">WorldCup Tickets</span>
                <span class="brand-subtitle">BD2 · Mundial 2026</span>
            </a>

            @if (isAuthenticated)
            {
                <div class="role-card">
                    <span>Sesión activa</span>
                    <strong>@User.Identity?.Name</strong>
                    <small>@string.Join(", ", User.FindAll(System.Security.Claims.ClaimTypes.Role).Select(r => r.Value))</small>
                </div>
            }

            <nav class="app-nav">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Eventos" asp-action="Index">Eventos</a>
                @if (!isAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                    <a asp-controller="Account" asp-action="Register">Registrarse</a>
                }
                else if (User.IsInRole(RolesAplicacion.Administrador))
                {
                    <a asp-controller="Admin" asp-action="Index">Dashboard</a>
                    <a asp-controller="Admin" asp-action="Estadios">Estadios</a>
                    <a asp-controller="Admin" asp-action="Sectores">Sectores</a>
                    <a asp-controller="Admin" asp-action="Equipos">Equipos</a>
                    <a asp-controller="Admin" asp-action="Eventos">Eventos</a>
                    <a asp-controller="Funcionalidades" asp-action="Funcionarios">Funcionarios</a>
                    <a asp-controller="Funcionalidades" asp-action="Reportes">Reportes</a>
                }
                else if (User.IsInRole(RolesAplicacion.Funcionario))
                {
                    <a asp-controller="Dashboard" asp-action="Funcionario">Dashboard</a>
                    <a asp-controller="Funcionalidades" asp-action="EventosAsignados">Eventos asignados</a>
                    <a asp-controller="Funcionalidades" asp-action="ValidarEntrada">Validar entrada</a>
                    <a asp-controller="Funcionalidades" asp-action="Validaciones">Validaciones</a>
                }
                else if (User.IsInRole(RolesAplicacion.UsuarioGeneral))
                {
                    <a asp-controller="Funcionalidades" asp-action="MisEntradas">Mis entradas</a>
                    <a asp-controller="Funcionalidades" asp-action="MisCompras">Mis compras</a>
                    <a asp-controller="Funcionalidades" asp-action="Transferencias">Transferencias</a>
                    <a asp-controller="Account" asp-action="Profile">Mi perfil</a>
                }
            </nav>

            @if (isAuthenticated)
            {
                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-auto">
                    <button type="submit" class="btn btn-outline-secondary w-100">Cerrar sesión</button>
                </form>
            }
        </aside>

        <header class="mobile-header">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                <span class="brand-title">WorldCup Tickets</span>
                <span class="brand-subtitle">Mundial 2026</span>
            </a>
            <div class="mobile-scroll-nav">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Eventos" asp-action="Index">Eventos</a>
                @if (!isAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login">Ingresar</a>
                    <a asp-controller="Account" asp-action="Register">Registro</a>
                }
                else
                {
                    <a asp-controller="Dashboard" asp-action="@dashboardAction">Dashboard</a>
                    <a asp-controller="Account" asp-action="Profile">Perfil</a>
                }
            </div>
        </header>

        <main class="app-main">
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger" role="alert">@error</div>
            }
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success" role="alert">@success</div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
