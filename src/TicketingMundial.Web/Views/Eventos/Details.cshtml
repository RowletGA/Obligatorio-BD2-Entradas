@model EventoDetalleViewModel
@{
    ViewData["Title"] = "Detalle de evento";
    var evento = Model.Evento;
    var puedeComprar = User.IsInRole(RolesAplicacion.UsuarioGeneral) && evento.Estado == "PROGRAMADO";
    var hayDisponibles = evento.Sectores.Any(s => s.LugaresDisponibles > 0);
}

<section class="mb-4">
    <a class="btn btn-link px-0" asp-action="Index">Volver</a>
    <h1 class="h3 mb-1">@(evento.EquipoLocal ?? "Local") vs @(evento.EquipoVisitante ?? "Visitante")</h1>
    <div class="text-secondary">@evento.FechaHora.ToString("dd/MM/yyyy HH:mm") - @evento.Estadio - @evento.LocalidadEstadio</div>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="summary-tile">
            <span>Estado</span>
            <strong>@evento.Estado</strong>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="summary-tile">
            <span>Estadio</span>
            <strong>@evento.Estadio</strong>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="summary-tile">
            <span>Sectores</span>
            <strong>@evento.Sectores.Count</strong>
        </div>
    </div>
</section>

<section class="content-panel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Comprar entradas</h2>
    </div>
    <form asp-controller="Compras" asp-action="Confirmar" method="post">
        <input type="hidden" name="IdEvento" value="@evento.IdEvento" />
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Sector</th>
                        <th class="text-end">Precio</th>
                        <th class="text-end">Emitidas</th>
                        <th class="text-end">Disponibles</th>
                        @if (puedeComprar)
                        {
                            <th class="text-end">Cantidad</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @if (evento.Sectores.Count == 0)
                {
                    <tr>
                        <td colspan="@(puedeComprar ? 5 : 4)" class="text-center text-secondary py-4">No hay sectores habilitados para este evento.</td>
                    </tr>
                }
                else
                {
                    @for (var i = 0; i < evento.Sectores.Count; i++)
                    {
                        var sector = evento.Sectores[i];
                        <tr>
                            <td class="fw-semibold">@sector.NombreSector</td>
                            <td class="text-end">@MoneyFormatter.Format(sector.PrecioBase)</td>
                            <td class="text-end">@sector.EntradasEmitidas</td>
                            <td class="text-end">
                                <span class="badge @(sector.LugaresDisponibles > 0 ? "text-bg-success" : "text-bg-danger")">
                                @sector.LugaresDisponibles
                                </span>
                            </td>
                            @if (puedeComprar)
                            {
                                <td class="text-end" style="width: 160px">
                                    <input type="hidden" name="Sectores[@i].IdSector" value="@sector.IdSector" />
                                    <input name="Sectores[@i].Cantidad" class="form-control text-end" type="number" min="0" max="5" value="0" disabled="@(sector.LugaresDisponibles <= 0)" />
                                </td>
                            }
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        @if (puedeComprar && hayDisponibles)
        {
            <button class="btn btn-primary mt-3">Continuar</button>
        }
    </form>
</section>
