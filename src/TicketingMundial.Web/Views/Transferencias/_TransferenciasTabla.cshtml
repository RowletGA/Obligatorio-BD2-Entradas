@model IReadOnlyList<TransferenciaDto>
@if (Model.Count == 0) { <p class="text-secondary mb-0">Sin transferencias.</p> }
else {
<div class="table-responsive"><table class="table align-middle"><thead><tr><th>ID</th><th>Entrada</th><th>Evento</th><th>Fecha evento</th><th>Solicitud</th><th>Respuesta</th><th>Estado</th><th>Otorga</th><th>Recibe</th><th></th></tr></thead><tbody>
@foreach (var t in Model) {
<tr><td>@t.IdTransferencia</td><td>@t.IdEntrada</td><td>@t.Evento</td><td>@t.FechaEvento.ToString("dd/MM/yyyy HH:mm")</td><td>@t.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td><td>@(t.FechaRespuesta?.ToString("dd/MM/yyyy HH:mm") ?? "Pendiente")</td><td>@t.Estado</td><td>@t.CorreoOtorga</td><td>@t.CorreoRecibe</td><td class="text-end">
@if (t.Estado == "PENDIENTE") {
<form asp-controller="Transferencias" asp-action="Aceptar" asp-route-id="@t.IdTransferencia" method="post" class="d-inline"><button class="btn btn-sm btn-outline-primary">Aceptar</button></form>
<form asp-controller="Transferencias" asp-action="Rechazar" asp-route-id="@t.IdTransferencia" method="post" class="d-inline"><button class="btn btn-sm btn-outline-secondary">Rechazar</button></form>
<form asp-controller="Transferencias" asp-action="Cancelar" asp-route-id="@t.IdTransferencia" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger">Cancelar</button></form>
}
</td></tr>}
</tbody></table></div>}
