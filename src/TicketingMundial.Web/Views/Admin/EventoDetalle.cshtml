@model EventoAdminDto
@using TicketingMundial.Domain.Estados
@{
    ViewData["Title"] = $"Evento {Model.IdEvento}";
    var edicionBloqueada = Model.EntradasEmitidas > 0 || EstadoEventoTransitions.EsCerrado(Model.EstadoEvento);
    var estadosPermitidos = EstadoEventoTransitions.ObtenerDestinosPermitidos(Model.EstadoEvento);
}

<section class="page-heading">
    <p class="section-kicker">Evento</p>
    <h1>@Model.EquipoLocal vs @Model.EquipoVisitante</h1>
    <p>@Model.FechaHora.ToString("f") · @Model.Estadio</p>
</section>

<section class="content-panel mb-3">
    @if (Model.EntradasEmitidas > 0)
    {
        <div class="alert alert-warning">
            Este evento ya tiene entradas emitidas. Para preservar la consistencia de las entradas, solamente puede modificarse su estado.
        </div>
    }
    else if (Model.EstadoEvento is "FINALIZADO" or "CANCELADO")
    {
        <div class="alert alert-warning">Los eventos finalizados o cancelados no permiten edición estructural.</div>
    }
    <div class="detail-grid">
        <div><span>Estado</span><strong>@Model.EstadoEvento</strong></div>
        <div><span>Estadio</span><strong>@Model.Estadio</strong></div>
        <div><span>País</span><strong>@Model.PaisEstadio</strong></div>
        <div><span>Entradas emitidas</span><strong>@Model.EntradasEmitidas</strong></div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-3">
        @if (!edicionBloqueada)
        {
            <a class="btn btn-primary" asp-action="EditarEvento" asp-route-id="@Model.IdEvento">Editar evento</a>
        }
    </div>
</section>

<section class="content-panel mb-3">
    <h2 class="h5">Cambiar estado</h2>
    <p class="text-secondary mb-3">Estado actual: <strong>@Model.EstadoEvento</strong></p>
    @if (estadosPermitidos.Count == 0)
    {
        <p class="text-secondary mb-0">Este evento no tiene transiciones disponibles.</p>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var estado in estadosPermitidos)
            {
                var confirmacion = estado switch
                {
                    EstadoEvento.Cancelado => "Al cancelar el evento se anularán todas las entradas no utilizadas. Esta operación no puede deshacerse. ¿Deseás continuar?",
                    EstadoEvento.Finalizado => "Al finalizar el evento, las entradas no utilizadas dejarán de ser válidas. Esta operación no puede deshacerse. ¿Deseás continuar?",
                    _ => null
                };
                <form asp-action="CambiarEstadoEvento" asp-route-id="@Model.IdEvento" method="post" onsubmit="@(confirmacion is null ? null : $"return confirm('{confirmacion}')")">
                    <input type="hidden" name="EstadoEvento" value="@estado" />
                    <button class="btn @(estado is EstadoEvento.Cancelado or EstadoEvento.Finalizado ? "btn-outline-danger" : "btn-outline-primary")">Pasar a @estado</button>
                    @if (confirmacion is not null)
                    {
                        <span class="text-secondary small ms-md-2 d-block d-md-inline mt-2 mt-md-0">Operación irreversible: anula entradas no utilizadas y cancela transferencias pendientes.</span>
                    }
                </form>
            }
        </div>
    }
</section>

<section class="content-panel">
    <h2 class="h5">Sectores habilitados</h2>
    @if (Model.Sectores.Count == 0)
    {
        <p class="text-secondary mb-0">Este evento no tiene sectores habilitados.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead><tr><th>Sector</th><th>Capacidad</th><th>Precio por entrada</th></tr></thead>
                <tbody>
                @foreach (var sector in Model.Sectores)
                {
                    <tr><td>@sector.NombreSector</td><td>@sector.Capacidad</td><td>@MoneyFormatter.Format(sector.PrecioBase)</td></tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
