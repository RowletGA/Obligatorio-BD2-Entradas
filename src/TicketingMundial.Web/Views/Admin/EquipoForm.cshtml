@model EquipoFormViewModel
@{
    ViewData["Title"] = Model.IdEquipo.HasValue ? "Editar equipo" : "Registrar equipo";
}

<section class="page-heading"><p class="section-kicker">Equipos</p><h1>@ViewData["Title"]</h1></section>
<form method="post" class="content-panel register-form">
    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
    <div class="form-section">
        <div>
            <label asp-for="Pais" class="form-label"></label>
            <select asp-for="Pais" asp-items="Model.Paises" class="form-select"><option value="">Seleccioná un país</option></select>
            <span asp-validation-for="Pais" class="text-danger small"></span>
        </div>
        <div>
            <label asp-for="Grupo" class="form-label"></label>
            <select asp-for="Grupo" asp-items="Model.Grupos" class="form-select"><option value="">Sin grupo</option></select>
            <span asp-validation-for="Grupo" class="text-danger small"></span>
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary">Guardar</button>
        <a class="btn btn-outline-secondary" asp-action="Equipos">Cancelar</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
