@model EventoCreateViewModel
@{
    var isEdit = Model.IdEvento.HasValue;
    ViewData["Title"] = isEdit ? "Editar evento" : "Crear evento";
    var disabled = Model.EdicionBloqueada;
}

<section class="page-heading"><p class="section-kicker">Eventos</p><h1>@(isEdit ? "Editar evento" : "Crear evento")</h1></section>
@if (!string.IsNullOrWhiteSpace(Model.AdvertenciaEdicion))
{
    <div class="alert alert-warning">@Model.AdvertenciaEdicion</div>
}
<form method="post" class="content-panel register-form">
    <input type="hidden" asp-for="IdEvento" />
    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
    <fieldset class="form-section">
        <legend>Datos del evento</legend>
        <div>
            <label asp-for="Fecha" class="form-label"></label>
            <input asp-for="Fecha" class="form-control" type="date" disabled="@disabled" />
            <span asp-validation-for="Fecha" class="text-danger small"></span>
        </div>
        <div>
            <label asp-for="Hora" class="form-label"></label>
            <input asp-for="Hora" class="form-control" type="time" disabled="@disabled" />
            <span asp-validation-for="Hora" class="text-danger small"></span>
        </div>
        <div>
            <label asp-for="EstadoEvento" class="form-label">Estado inicial</label>
            <select asp-for="EstadoEvento" asp-items="Model.Estados" class="form-select" disabled="@disabled"></select>
            <span asp-validation-for="EstadoEvento" class="text-danger small"></span>
        </div>
        <div>
            <label asp-for="IdEstadio" class="form-label">Estadio</label>
            <select asp-for="IdEstadio" asp-items="Model.Estadios" class="form-select" onchange="this.form.method='get'; this.form.submit();" disabled="@disabled"><option value="">Seleccioná un estadio</option></select>
            <span asp-validation-for="IdEstadio" class="text-danger small"></span>
        </div>
        <div>
            <label asp-for="IdEquipoLocal" class="form-label">Equipo local</label>
            <select asp-for="IdEquipoLocal" asp-items="Model.Equipos" class="form-select" disabled="@disabled"><option value="">Seleccioná equipo</option></select>
            <span asp-validation-for="IdEquipoLocal" class="text-danger small"></span>
        </div>
        <div>
            <label asp-for="IdEquipoVisitante" class="form-label">Equipo visitante</label>
            <select asp-for="IdEquipoVisitante" asp-items="Model.Equipos" class="form-select" disabled="@disabled"><option value="">Seleccioná equipo</option></select>
            <span asp-validation-for="IdEquipoVisitante" class="text-danger small"></span>
        </div>
    </fieldset>

    <fieldset class="form-section">
        <legend>Sectores habilitados</legend>
        <span asp-validation-for="Sectores" class="text-danger small"></span>
        @if (Model.Sectores.Count == 0)
        {
            <p class="text-secondary mb-0">Seleccioná un estadio con sectores cargados para habilitar precios.</p>
        }
        else
        {
            @for (var i = 0; i < Model.Sectores.Count; i++)
            {
                <div class="sector-option">
                    <input type="hidden" asp-for="Sectores[i].IdSector" />
                    <input type="hidden" asp-for="Sectores[i].NombreSector" />
                    <input type="hidden" asp-for="Sectores[i].Capacidad" />
                    <div class="form-check">
                        <input asp-for="Sectores[i].Seleccionado" class="form-check-input" data-sector-check disabled="@disabled" />
                        <label asp-for="Sectores[i].Seleccionado" class="form-check-label">@Model.Sectores[i].NombreSector</label>
                    </div>
                    <div class="text-secondary small mt-1">Capacidad: @Model.Sectores[i].Capacidad personas</div>
                    <label asp-for="Sectores[i].PrecioBase" class="form-label mt-2">Precio por entrada</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Sectores[i].PrecioBase" class="form-control" type="number" step="0.01" min="0.01" placeholder="Ej.: 1200.00" data-sector-price disabled="@(disabled || !Model.Sectores[i].Seleccionado)" />
                    </div>
                    <span asp-validation-for="Sectores[i].PrecioBase" class="text-danger small"></span>
                </div>
            }
        }
    </fieldset>
    <div class="d-flex gap-2 mt-3">
        @if (!disabled)
        {
            <button class="btn btn-primary">@(isEdit ? "Guardar cambios" : "Crear evento")</button>
        }
        <a class="btn btn-outline-secondary" asp-action="Eventos">Cancelar</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
