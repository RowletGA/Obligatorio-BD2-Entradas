@model AdminListViewModel<SectorAdminDto>
@{
    ViewData["Title"] = "Sectores";
    string SortUrl(string sort)
    {
        var direction = Model.Sort == sort && Model.Direction != "asc" ? "asc" : "desc";
        return Url.Action("Sectores", new { Model.IdEstadio, q = Model.Busqueda, sort, direction, page = Model.Results.Page, pageSize = Model.Results.PageSize }) ?? "#";
    }
    string Indicator(string sort) => Model.Sort == sort ? (Model.Direction == "asc" ? " ↑" : " ↓") : string.Empty;
}

<section class="page-heading"><p class="section-kicker">Administración</p><h1>Sectores</h1></section>
<section class="content-panel">
    <div class="section-toolbar">
        <form method="get" class="d-flex flex-wrap gap-2">
            <select name="idEstadio" asp-items="Model.Estadios" class="form-select"><option value="">Todos los estadios</option></select>
            <input name="q" value="@Model.Busqueda" class="form-control" placeholder="Buscar sector o estadio" />
            <select name="pageSize" class="form-select" style="max-width: 100px"><option selected="@(Model.Results.PageSize == 10)">10</option><option selected="@(Model.Results.PageSize == 25)">25</option><option selected="@(Model.Results.PageSize == 50)">50</option></select>
            <button class="btn btn-outline-primary">Filtrar</button>
        </form>
        <a class="btn btn-primary" asp-action="NuevoSector">Crear sector</a>
    </div>
    @if (Model.Results.Items.Count == 0)
    {
        <p class="text-secondary mt-3 mb-0">No hay sectores para mostrar.</p>
    }
    else
    {
        <div class="table-responsive mt-3">
            <table class="table align-middle">
                <thead><tr><th><a class="sortable-link" href="@SortUrl("nombre")">@($"Sector{Indicator("nombre")}")</a></th><th><a class="sortable-link" href="@SortUrl("capacidad")">@($"Capacidad{Indicator("capacidad")}")</a></th><th><a class="sortable-link" href="@SortUrl("estadio")">@($"Estadio{Indicator("estadio")}")</a></th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model.Results.Items)
                {
                    <tr>
                        <td>@item.NombreSector</td>
                        <td>@item.Capacidad</td>
                        <td>@item.Estadio</td>
                        <td class="text-end"><a class="btn btn-outline-primary btn-sm" asp-action="EditarSector" asp-route-id="@item.IdSector">Editar</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    @if (Model.Results.TotalPages > 1) { <div class="d-flex justify-content-between align-items-center mt-3"><span class="text-secondary">Página @Model.Results.Page de @Model.Results.TotalPages</span><div class="d-flex gap-2"><a class="btn btn-outline-secondary btn-sm @(Model.Results.Page <= 1 ? "disabled" : null)" asp-action="Sectores" asp-route-idEstadio="@Model.IdEstadio" asp-route-q="@Model.Busqueda" asp-route-sort="@Model.Sort" asp-route-direction="@Model.Direction" asp-route-page="@(Model.Results.Page - 1)" asp-route-pageSize="@Model.Results.PageSize">Anterior</a><a class="btn btn-outline-secondary btn-sm @(Model.Results.Page >= Model.Results.TotalPages ? "disabled" : null)" asp-action="Sectores" asp-route-idEstadio="@Model.IdEstadio" asp-route-q="@Model.Busqueda" asp-route-sort="@Model.Sort" asp-route-direction="@Model.Direction" asp-route-page="@(Model.Results.Page + 1)" asp-route-pageSize="@Model.Results.PageSize">Siguiente</a></div></div> }
</section>
