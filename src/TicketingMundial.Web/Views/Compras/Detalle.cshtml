@model CompraDetalleDto
@{
    ViewData["Title"] = "Detalle de compra";
}
<section class="page-heading"><p class="section-kicker">Compra</p><h1>@VisualCodeFormatter.Venta(Model.Venta.NumeroVisual)</h1><p>@Model.Venta.FechaVenta.ToString("dd/MM/yyyy HH:mm") · <span class="@StatusBadgeHelper.Venta(Model.Venta.EstadoVenta)">@Model.Venta.EstadoVenta</span></p></section>
<section class="content-panel">
<div class="detail-grid mb-3"><div><span>Entradas</span><strong>@Model.Venta.CantidadEntradas</strong></div><div><span>Comisión</span><strong>@Model.Venta.PorcentajeComision.ToString("N2")%</strong></div><div><span>Total</span><strong>@MoneyFormatter.Format(Model.Venta.MontoTotal)</strong></div></div>
<div class="table-responsive"><table class="table"><thead><tr><th>Entrada</th><th>Evento</th><th>Sector</th><th>Estado</th><th>Costo</th></tr></thead><tbody>
@foreach (var e in Model.Entradas) { <tr><td>@(e.NumeroVisual > 0 ? VisualCodeFormatter.Entrada(e.NumeroVisual) : $"#{e.IdEntrada}")</td><td>@e.Evento</td><td>@e.Sector</td><td><span class="@StatusBadgeHelper.Entrada(e.EstadoEntrada)">@e.EstadoEntrada</span></td><td>@MoneyFormatter.Format(e.Costo)</td></tr> }
</tbody></table></div>
</section>
