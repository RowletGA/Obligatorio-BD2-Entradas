@model CompraDetalleDto
@{
    ViewData["Title"] = $"Compra {Model.Venta.IdVenta}";
}
<section class="page-heading"><p class="section-kicker">Compra</p><h1>Compra @Model.Venta.IdVenta</h1><p>@Model.Venta.FechaVenta.ToString("g") · @Model.Venta.EstadoVenta</p></section>
<section class="content-panel">
<div class="detail-grid mb-3"><div><span>Entradas</span><strong>@Model.Venta.CantidadEntradas</strong></div><div><span>Comisión</span><strong>@Model.Venta.PorcentajeComision%</strong></div><div><span>Total</span><strong>$ @Model.Venta.MontoTotal.ToString("N2")</strong></div></div>
<div class="table-responsive"><table class="table"><thead><tr><th>Entrada</th><th>Evento</th><th>Sector</th><th>Estado</th><th>Costo</th></tr></thead><tbody>
@foreach (var e in Model.Entradas) { <tr><td>@e.IdEntrada</td><td>@e.Evento</td><td>@e.Sector</td><td>@e.EstadoEntrada</td><td>$ @e.Costo.ToString("N2")</td></tr> }
</tbody></table></div>
</section>
