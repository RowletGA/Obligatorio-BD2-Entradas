@model CompraPreviewDto
@{
    ViewData["Title"] = "Confirmar compra";
}

<section class="page-heading">
    <p class="section-kicker">Compra</p>
    <h1>Confirmar compra</h1>
    <p>@Model.Evento · @Model.FechaHora.ToString("g") · @Model.Estadio</p>
</section>

<form asp-action="Comprar" method="post" class="content-panel">
    <input type="hidden" name="IdEvento" value="@Model.IdEvento" />
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Sector</th><th>Cantidad</th><th>Precio</th><th>Subtotal</th></tr></thead>
            <tbody>
            @for (var i = 0; i < Model.Lineas.Count; i++)
            {
                <tr>
                    <td>@Model.Lineas[i].Sector</td>
                    <td>@Model.Lineas[i].Cantidad</td>
                    <td>@MoneyFormatter.Format(Model.Lineas[i].PrecioUnitario)</td>
                    <td>@MoneyFormatter.Format(Model.Lineas[i].Subtotal)</td>
                </tr>
                <input type="hidden" name="Sectores[@i].IdSector" value="@Model.Lineas[i].IdSector" />
                <input type="hidden" name="Sectores[@i].Cantidad" value="@Model.Lineas[i].Cantidad" />
            }
            </tbody>
        </table>
    </div>
    <div class="detail-grid">
        <div><span>Subtotal</span><strong>@MoneyFormatter.Format(Model.Subtotal)</strong></div>
        <div><span>Comisión</span><strong>@Model.PorcentajeComision.ToString("N2")%</strong></div>
        <div><span>Total estimado</span><strong>@MoneyFormatter.Format(Model.Total)</strong></div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary">Confirmar compra</button>
        <a class="btn btn-outline-secondary" asp-controller="Eventos" asp-action="Details" asp-route-id="@Model.IdEvento">Cancelar</a>
    </div>
</form>
