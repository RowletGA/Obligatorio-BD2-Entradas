@model IReadOnlyList<CompraResumenDto>
@{
    ViewData["Title"] = "Mis compras";
}
<section class="page-heading"><p class="section-kicker">Usuario</p><h1>Mis compras</h1></section>
<section class="content-panel">
@if (Model.Count == 0) { <p class="text-secondary mb-0">No tenés compras registradas.</p> }
else {
<div class="table-responsive"><table class="table align-middle"><thead><tr><th>Venta</th><th>Fecha</th><th>Estado</th><th>Entradas</th><th>Total</th><th></th></tr></thead><tbody>
@foreach (var c in Model) { <tr><td>@c.IdVenta</td><td>@c.FechaVenta.ToString("g")</td><td>@c.EstadoVenta</td><td>@c.CantidadEntradas</td><td>$ @c.MontoTotal.ToString("N2")</td><td><a asp-action="Detalle" asp-route-id="@c.IdVenta">Ver</a></td></tr> }
</tbody></table></div>}
</section>
